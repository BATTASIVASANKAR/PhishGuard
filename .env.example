# ============================================================
# PhishGuard — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values below.
# Never commit your real .env to source control.
# ============================================================

# ------------------------------------------------------------
# VirusTotal API Key (REQUIRED for VirusTotal Intelligence)
# ------------------------------------------------------------
# How to get a FREE key:
#   1. Go to https://www.virustotal.com/gui/join-us
#   2. Create a free account (email required)
#   3. After logging in, visit https://www.virustotal.com/gui/my-apikey
#   4. Copy your API key (64-character hex string)
#   5. Paste it below (replace the placeholder)
#
# Free plan limits: 4 lookups/min, 500 lookups/day
# ------------------------------------------------------------
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ------------------------------------------------------------
# BuiltWith API Key (OPTIONAL — tech detection works without it)
# ------------------------------------------------------------
# Free key available at: https://api.builtwith.com/free-key
# Leave blank to use header-based detection only.
# ------------------------------------------------------------
BUILTWITH_API_KEY=

# ------------------------------------------------------------
# Flask Secret Key
# ------------------------------------------------------------
# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------
SECRET_KEY=phishguard-secret-change-me

# ------------------------------------------------------------
# Request timeout (seconds) for external API calls
# Increase this on slow networks (recommended: 10)
# ------------------------------------------------------------
REQUEST_TIMEOUT=10
